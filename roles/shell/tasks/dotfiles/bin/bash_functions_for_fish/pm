#!/bin/bash

# This evaluates to `pacman ...` or `sudo pacman ...` if needed
function pm {
  case $1 in
    -Syu)
      pnotify "Starting system upgrade ..."
      sudo pacman "$@"
      psuccess "System upgrade done." ;;
    -S | -D | -S[^sih]* | -R* | -U*)
      sudo pacman "$@" ;;
    *)
      pacman "$@" ;;
  esac
}

pm $@
