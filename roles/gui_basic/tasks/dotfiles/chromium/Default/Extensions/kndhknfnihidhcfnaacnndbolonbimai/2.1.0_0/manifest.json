{
   "background": {
      "persistent": true,
      "scripts": [ "background.js" ]
   },
   "content_scripts": [ {
      "js": [ "content.js" ],
      "matches": [ "*://www.twitch.tv/*", "*://player.twitch.tv/*" ],
      "run_at": "document_start"
   } ],
   "description": "Block ads on that certain streaming website",
   "key": "",
   "manifest_version": 2,
   "name": "TTV ad-block",
   "options_ui": {
      "open_in_tab": true,
      "page": "options.html"
   },
   "permissions": [ "*://*.twitch.tv/*", "*://*.ttvnw.net/*", "webRequest", "webRequestBlocking" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "2.1.0"
}
